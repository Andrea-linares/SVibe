<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SVibe"
        tools:targetApi="31">

        <!-- NUEVA SPLASH SCREEN -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SVibe">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Pantalla de invitado (LAUNCHER) -->
        <activity
            android:name=".auth.GuestLoginActivity"
            android:exported="true"
            android:theme="@style/Theme.SVibe">
        </activity>

        <!-- Pantalla de inicio temporal -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />


        <activity android:name=".RosalesActivity"/>
        <activity android:name=".QuelepaActivity"/>
        <activity android:name=".ChaparrastiqueActivity"/>
        <activity android:name=".JocotalActivity"/>
        <activity android:name=".MiradorActivity"/>
        <activity android:name=".LagunaAlegriaActivity"/>
        <activity android:name=".CienGradasActivity"/>
        <activity android:name=".MuseoActivity"/>
        <activity android:name=".TeatroActivity"/>
        <activity android:name=".ParqueActivity"/>
        <activity android:name=".CapillaActivity"/>
        <activity android:name=".CatedralActivity"/>
        <activity android:name=".RaudaActivity"/>
        <activity android:name=".CuevasActivity"/>
        <activity android:name=".MapActivity"/>

        <activity android:name=".OcultosActivity"/>
        <activity android:name=".BosqueImposibleActivity"/>
        <activity android:name=".CascadaTerciosActivity"/>
        <activity android:name=".PenonComasaguaActivity"/>
        <activity android:name=".PuertaDiabloActivity"/>
        <activity android:name=".ChorrosCaleraActivity"/>
        <activity android:name=".LagunaVerdeActivity"/>
    </application>

</manifest>